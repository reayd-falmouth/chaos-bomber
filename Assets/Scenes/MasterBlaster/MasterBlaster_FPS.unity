MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1196422717}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0, g: 0.121568635, b: 0.82745105, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 8d22e2817713f45499af9f7d75b1c137, type: 2}
    m_FontSize: 16
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 169
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1.58
  m_Text: "WELCOME TO THE EDGE OF THE END.\n\n\nYOU ARE CURRENTLY STANDING IN THE
    MOST EXPENSIVE REAL ESTATE IN THE GALAXY\n\nNOT BECAUSE OF THE VIEW\n\nBUT BECAUSE
    OF THE EXPIRATION DATE. \n\nTONIGHT THE \"PLAYERS OF THE EVE OF DESTRUCTION\"
    HAVE GATHERED IN THE SHADOW OF A DYING SUN\n\nATOP A SINKING ARCHIPELAGO\n\nAND
    WITHIN THE CRACKING DOMES OF THE LAST CITIES.\n\nWHY?\n\nBECAUSE VICTORY IS SWEETER
    WHEN THE FLOOR IS LITERALLY MELTING.\n\nIN THE WORLD OF MASTER BLASTER\n\nTHERE
    ARE NO HEROES AND NO GRAND CRUSADES\n\nONLY THE GRID\n\nTHE BOMB\n\nAND THE BEAUTIFUL,
    CHAOTIC TICKING OF THE CLOCK. \n\nTHE UNIVERSE IS FALLING APART\n\nYOU MIGHT
    AS WELL BE THE ONE HOLDING THE DETONATOR WHEN IT DOES.\n\nPLACE YOUR BETS. \n\nPRIME
    YOUR CHARGES. \n\nTRY NOT TO FALL.\r\n"
