require "json"
require "xcodeproj"

def agent_debug_log(hypothesis_id:, message:, data: {}, run_id: "run1")
  payload = {
    sessionId: "b8269a",
    runId: run_id,
    hypothesisId: hypothesis_id,
    location: "fastlane/Fastfile",
    message: message,
    data: data,
    timestamp: (Time.now.to_f * 1000).to_i
  }
  # region agent log
  File.open("debug-b8269a.log", "a") { |f| f.puts(payload.to_json) }
  # endregion
rescue StandardError
  nil
end

def remove_playfab_simulator_framework_from_target!(target, simulator_suffix)
  removed_entries = []
  phases = [target.frameworks_build_phase] + target.copy_files_build_phases

  phases.compact.each do |phase|
    phase.build_files.dup.each do |build_file|
      file_ref = build_file.file_ref
      next if file_ref.nil?

      ref_path = file_ref.path.to_s
      next unless ref_path.end_with?(simulator_suffix)

      removed_entries << {
        phase: phase.display_name,
        path: ref_path
      }
      phase.remove_build_file(build_file)
    end
  end

  removed_entries
end

def collect_playfab_target_entries(target, playfab_suffix)
  phases = [target.frameworks_build_phase] + target.copy_files_build_phases
  entries = []

  phases.compact.each do |phase|
    phase.build_files.each do |build_file|
      file_ref = build_file.file_ref
      next if file_ref.nil?

      ref_path = file_ref.path.to_s
      next unless ref_path.end_with?(playfab_suffix)

      entries << {
        phase: phase.display_name,
        path: ref_path
      }
    end
  end

  entries
end

def sanitize_playfab_framework_entries!(xcodeproj_path:, target_name: "Unity-iPhone")
  simulator_suffix = "Frameworks/Plugins/PlayFabPartySDK/Source/DLLs/Apple/Simulator/PlayFabParty.framework"
  playfab_suffix = "PlayFabParty.framework"
  project_file = File.join(xcodeproj_path, "project.pbxproj")
  UI.user_error!("Missing Xcode project at #{xcodeproj_path}") unless File.directory?(xcodeproj_path)
  UI.user_error!("Missing project file at #{project_file}") unless File.file?(project_file)

  project = Xcodeproj::Project.open(xcodeproj_path)
  target = project.targets.find { |t| t.name == target_name }
  UI.user_error!("Target '#{target_name}' not found in #{xcodeproj_path}") if target.nil?

  removed_entries = remove_playfab_simulator_framework_from_target!(target, simulator_suffix)
  project.save if removed_entries.any?

  all_playfab_entries = collect_playfab_target_entries(target, playfab_suffix)
  simulator_entries = all_playfab_entries.select { |entry| entry[:path].end_with?(simulator_suffix) }

  agent_debug_log(
    hypothesis_id: "H4_playfab_sanitize",
    message: "Sanitized PlayFabParty framework entries",
    data: {
      project: xcodeproj_path,
      target: target_name,
      removed_count: removed_entries.length,
      removed_entries: removed_entries,
      remaining_count: all_playfab_entries.length,
      remaining_entries: all_playfab_entries
    }
  )

  UI.user_error!(
    "Sanitization failed: Simulator PlayFabParty.framework still referenced in #{target_name}: #{simulator_entries}"
  ) if simulator_entries.any?
end

platform :ios do
  desc "Sync codesigning certificates"
  lane :sync_certificates do
    app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_P8"]
    )

    match(
      type: "appstore",
      readonly: false
    )
  end

  desc "Deliver a new Beta build to Apple TestFlight"
  lane :beta do
    update_info_plist(
      xcodeproj: "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj",
      plist_path: "Info.plist",
      block: proc do |plist|
        plist["ITSAppUsesNonExemptEncryption"] = false
      end
    )

    build
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Create .ipa"
  lane :build do
    setup_ci

    sync_certificates

    workspace_path = "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcworkspace"
    project_path = "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj"
    use_workspace = File.directory?(workspace_path)
    agent_debug_log(
      hypothesis_id: "H1_workspace_missing",
      message: "Resolved Xcode container paths",
      data: {
        ios_build_path: ENV["IOS_BUILD_PATH"],
        workspace_path: workspace_path,
        workspace_exists: use_workspace,
        project_path: project_path,
        project_exists: File.directory?(project_path)
      }
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore_team-id"],
      code_sign_identity: "iPhone Distribution",
      targets: "Unity-iPhone",
      path: "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj",
      profile_name: ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore_profile-name"],
      profile_uuid: ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore"]
    )

    sanitize_playfab_framework_entries!(xcodeproj_path: project_path, target_name: "Unity-iPhone")

    if use_workspace
      agent_debug_log(
        hypothesis_id: "H2_workspace_branch",
        message: "Using xcworkspace for build_app",
        data: { path: workspace_path }
      )
      build_app(
        workspace: workspace_path,
        scheme: "Unity-iPhone"
      )
    else
      agent_debug_log(
        hypothesis_id: "H3_project_fallback",
        message: "Using xcodeproj fallback for build_app",
        data: { path: project_path }
      )
      build_app(
        project: project_path,
        scheme: "Unity-iPhone"
      )
    end
  end
end
